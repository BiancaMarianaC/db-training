# ============================================================================
# TradeFlow .gitignore
# ============================================================================

# --- Java / Maven ---------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
.mvn/*
!.mvn/wrapper/
hs_err_pid*

# --- IDE -----------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.vscode/
.project
.classpath
.settings/

# --- Node / Frontend -----------------------------------------------------
node_modules/
dist/
build/
.npm/
.pnp/
.pnp.js

# --- Logs ----------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Spring / Application secrets ----------------------------------------
.env
.env.local
.env.*.local
application-secret.yml
application-local.yml

# --- OS ------------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Docker --------------------------------------------------------------
.docker-volumes/

# --- Coverage / Test output ----------------------------------------------
coverage/
.nyc_output/
jacoco.exec
surefire-reports/
